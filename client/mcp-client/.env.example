# ============================================
# FarmMind MCP Client 配置文件示例
# ============================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填写你的实际配置值
# 3. 不要将 .env 文件提交到 Git 仓库
# ============================================

# ==================== LLM 配置 ====================
# API 密钥（Ollama 本地部署可填任意值，如 "ollama"）
API_KEY=your_api_key_here

# API 基础地址
# - Ollama 本地: http://localhost:11434/v1
# - OpenAI: https://api.openai.com/v1
# - 其他兼容服务: 填写对应的 base_url
BASE_URL=http://localhost:11434/v1

# 模型名称
# - Ollama 示例: qwen2.5-coder, llama3, deepseek-coder
# - OpenAI 示例: gpt-4, gpt-3.5-turbo
MODEL=qwen2.5-coder

# ==================== 天气服务配置 ====================
# OpenWeatherMap API Key
# 获取方式：
# 1. 访问 https://openweathermap.org/api
# 2. 注册免费账号
# 3. 在 API keys 页面生成密钥
# 注意：免费版有调用次数限制（60次/分钟，1000次/天）
OWM_API_KEY=your_openweathermap_api_key_here

# ==================== 可选配置 ====================
# 日志级别 (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# 连接超时时间（秒）
# CONNECTION_TIMEOUT=60

# 工具调用超时时间（秒）
# TOOL_TIMEOUT=120
