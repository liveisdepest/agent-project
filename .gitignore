# ... existing code ...

# Environment and configuration files
# 忽略所有 .env 文件（包含敏感信息）
.env
*.env
.env.*
# 但保留 .env.example 模板文件
!.env.example
!**/.env.example

# 忽略可能包含敏感信息的配置文件
client/mcp-client/config.json
# mcp_servers.json 不包含敏感信息，应该提交

# API keys and secrets
**/api_keys.txt
**/secrets.json
**/*.key
# ... existing code ...

# IDE / editor settings
.idea/
.vscode/
.trae/

# Python cache
__pycache__/
*.py[cod]

# Local databases and logs
*.db
*.log
debug_log.txt

# 忽略虚拟环境文件
.venv

# 忽略前端依赖包
**/node_modules
